#include <stdio.h>

int main() {
    int n, target;

    // Take number of elements (product IDs)
    printf("Enter number of products: ");
    scanf("%d", &n);

    int arr[n];  // Array to store product IDs

    // Take sorted product IDs as input
    printf("Enter sorted product IDs:\n ");
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Take the product ID to search
    printf("Enter product ID to search: ");
    scanf("%d", &target);

    // Initialize low and high pointers
    int low = 0, high = n - 1;
    int found = 0;  // Flag to check if element is found

    // Binary Search logic
    while(low <= high) {
        int mid = (low + high) / 2;  // Find middle index

        if(arr[mid] == target) {
            // If target is found
            found = 1;
            break;
        }
        else if(arr[mid] < target) {
            // If target is greater, search in right half
            low = mid + 1;
        }
        else {
            // If target is smaller, search in left half
            high = mid - 1;
        }
    }

    // Print result
    if(found)
        printf("Product Available\n");
    else
        printf("Product Not Available\n");

    return 0;
}