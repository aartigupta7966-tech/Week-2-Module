#include <stdio.h>
int main() {
    int n;
    // Take users input(number of students)
    printf("Enter number of students: ");
    scanf("%d", &n);

    int arr[n];//array of size n

    // Take exam scores as input
    printf("Enter the scores:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Bubble Sort logic 
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {

            // Compare adjacent elements
            if(arr[j] > arr[j + 1]) {
                // Swap it to right order
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }

    // Print sorted array
    printf("Sorted scores:\n");
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}