#include <stdio.h>
int main() {
    int n;
    // Take number of books
    printf("Enter number of books: ");
    scanf("%d", &n);
    int arr[n];  // Array to store book numbers
    // Take book numbers as input
    printf("Enter the book numbers:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    // Insertion Sort logic 
    for(int i = 1; i < n; i++) {
        int key = arr[i];   // Current element to be placed correctly
        int j = i - 1;

        // Shift elements that are greater than key
        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        // Place key at correct position
        arr[j + 1] = key;
    }

    // Print sorted book numbers
    printf("Sorted book numbers:\n");
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}