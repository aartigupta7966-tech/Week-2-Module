#include <stdio.h>
int main()
{
    int n, i, x;
    int found = 0;
//taking no of students as an input from user
    printf("Enter number of students: ");
    scanf("%d", &n);
//input n roll numbers from user
    int rollno[n];
    printf("Enter %d roll numbers:\n", n);
    for(i = 0; i < n; i++)
    {
        scanf("%d", &rollno[i]);
    }

    printf("Enter roll number to search: ");//input roll number to be searched
    scanf("%d", &x);
    // Linear Search
    for(i = 0; i < n; i++)
    {
        if(rollno[i] == x){
          printf("Found at index %d", i);
            found = 1;
            break;
        }
    }
    if(found == 0){
        printf("Not Found");
    }
    return 0;
}